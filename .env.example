# ═══════════════════════════════════════════════════
# Smooth by June — Environment Variables
# ═══════════════════════════════════════════════════
#
# Kopieer dit bestand naar .env voor lokaal testen.
# Op Railway: voeg deze variabelen toe via het
# "Variables" tabblad in je project.
#
# SMTP-gegevens vind je bij Cloud86:
# Mijn Cloud86 → Hosting → E-mail → SMTP instellingen
# ═══════════════════════════════════════════════════

# SMTP server van Cloud86 (of jouw e-mailprovider)
SMTP_HOST=mail.cloud86.nl

# Poort: 587 (TLS/STARTTLS) of 465 (SSL)
SMTP_PORT=587

# false = STARTTLS (poort 587), true = SSL (poort 465)
SMTP_SECURE=false

# Het e-mailadres van June — dit is ook de afzender
SMTP_USER=info@smoothbyjune.be

# Het wachtwoord van info@smoothbyjune.be
SMTP_PASS=VERVANG_MET_ECHT_WACHTWOORD

# Poort waarop de server draait (Railway zet dit automatisch)
PORT=3000
